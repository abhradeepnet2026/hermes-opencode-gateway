# ============================================================
# Hermes ↔ OpenCode Gateway — configuration
# Copy this file to `.env` and edit values as needed.
# All settings can also be overridden via real env vars.
# ============================================================

# --- Server ---
# Port the gateway listens on (Hermes Agent will point here)
GATEWAY_HOST=127.0.0.1
GATEWAY_PORT=8787

# --- Authentication ---
# Comma-separated list of accepted API keys. If empty, auth is disabled.
# Hermes should send any of these as `Authorization: Bearer <key>`.
GATEWAY_API_KEYS=

# --- Rate limiting ---
# Simple in-memory token-bucket. Per-key limits.
GATEWAY_RATE_LIMIT_RPM=60
GATEWAY_RATE_LIMIT_BURST=10

# --- OpenCode CLI ---
# Path to the opencode binary. If empty, resolved via PATH.
OPENCODE_BIN=opencode
# Working directory for opencode invocations (defaults to CWD)
OPENCODE_WORKDIR=
# Hard timeout (seconds) for a single opencode run invocation
OPENCODE_TIMEOUT=300
# Default model when Hermes doesn't specify one (provider/model)
OPENCODE_DEFAULT_MODEL=opencode/big-pickle
# Default agent (leave empty for opencode's built-in default)
OPENCODE_DEFAULT_AGENT=
# Extra CLI flags appended to every `opencode run` invocation
OPENCODE_EXTRA_FLAGS=

# --- Logging ---
# Log level: DEBUG | INFO | WARNING | ERROR
GATEWAY_LOG_LEVEL=INFO
